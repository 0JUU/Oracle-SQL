/*
  <함수 FUNCTION>
  JAVA로 따지면 메소드와 같은 존재
  매개변수로 전달된 값들을 읽어서 계산한 결과를 반환
  
  - 단일행  함수 : 8개의 값을 읽어서 8개의 결과를 리턴(매 행마다 함수 실행 후 결과 반환)
  - 그룹 함수 : 8개의 값을 읽어서 1개의 결과를 리턴(하나의 그룹별로 함수 실행 후 결과 반환)
  
  단일행 함수와 그룹 함수는 함께 사용할 수 없음 : 결과 행의 개수가 다르기 때문
  
*/

-------------------------------단일행 함수-------------------------------------
/*
   <문자열과 관련된 함수>
   LENGTH / LENGTHB
   
   -LENGTH(문자열) : 해당 전달된 문자열의 글자 수 반환
   -LENGTHB(문자열) : 해당 전달된 문자열의 바이트 수 반환
   
   결과값은 숫자로 반환 -> NUMBER
   문자열 : 문자열 형식의 리터럴, 문자열에 해당한느 컬럼
   
   한글 : '김'(3BYTE), 'ㄱ'(3BYTE), 'ㅣ'(3BYTE), 'ㅁ'(3BYTE) -> 한 글자 당 3BYTE로 취급한다.
   영문, 숫자, 특수문자는 한 글자 당 1BYTE로 취급한다.
*/

SELECT LENGTH('오라클'), LENGTHB('오라클')
FROM DUAL;     -- 가상테이블 : 산술연산이나 가상컬럼 등 값을 한 번만 조회하기 위해 사용하는 가상테이블

SELECT '오라클', 1, 2, 'AAA'
FROM DUAL;

SELECT EMAIL, LENGTH(EMAIL), LENGTHB(EMAIL), EMP_NAME, LENGTH(EMP_NAME), LENGTHB(EMP_NAME)
FROM EMPLOYEE;



/*
    INSTR
    -INSTR(문자열, 특정 문자, 찾을 위치의 시작값, 순번) : 문자열로부터 특정 문자의 위치값 반환
    찾을 위치의 시작값, 순번은 생략 가능
    결과값은 NUMBER타입으로 반환
    찾을 위치의 시작값(1 / -1)
    1 : 앞에서부터 찾겠다(생략 시 기본값)
    -1 : 뒤에서부터 찾겠다
*/

SELECT INSTR('AABAAABBBAA', 'B')
FROM DUAL;  -- 앞에서부터 첮 번째에 위치하는 B의 위치값을 알려줌

SELECT INSTR('AABAAABBBAA', 'B', 1)
FROM DUAL;  -- 앞에서부터 첫 번째에 위치하는 B의 위치값을 앞에서부터 세서 알려줌

SELECT INSTR('AABAAABBBAA', 'B', -1)
FROM DUAL;  -- 뒤에서부터 첫 번째에 위치하는 B의 위치값을 앞에서부터 세서 알려줌

SELECT INSTR('AABAAABBBAA', 'B', -1, 2)
FROM DUAL;  -- 뒤에서부터 두 번째에 위치하는 B의 위치값을 앞에서부터 세서 알려줌

SELECT INSTR('AABAAABBBAA', 'B', 1, 2)
FROM DUAL;  -- 앞에서부터 두 번째에 위치하는 B의 위치값을 앞에서부터 세서 알려줌
-- JAVA처럼 0부터가 아니라 1부터 시작

--EMAIL에서 @ 위치 찾기
SELECT INSTR(EMAIL, '@')
FROM EMPLOYEE;




/*
    SUBSTR
    문자열로부터 특정 문자열을 추출하는 함수
    -SUBSTR(문자열, 처음위치, 추출할 문자개수)
    결과값은 CHARACTER 타입으로 반환된다.(문자열)
    추출할 문자 개수는 생략 가능(생략 시 문자열 끝까지 추출)
    처음위치는 음수로 제시 가능 : 뒤에서부터 8번째 위치로부터 문자를 추출하겠다.
*/

SELECT SUBSTR('HELLO ORACLE', 5)
FROM DUAL;

SELECT SUBSTR('HELLO ORACLE', 5, 5)
FROM DUAL;

SELECT SUBSTR('HELLO ORACLE', -2)
FROM DUAL;

SELECT SUBSTR('HELLO ORACLE', -5, 3)
FROM DUAL;

--주민등록번호에서 성별 부분을 추출해서 확인하기
SELECT EMP_NAME "이름", SUBSTR(EMP_NO, 8, 1) "성별"
FROM EMPLOYEE;
--남사원 뽑기
SELECT *
FROM EMPLOYEE
WHERE SUBSTR(EMP_NO, 8, 1) IN('1', '3');

--이메일에서 ID 부분만 추출하기
SELECT EMP_NAME, EMAIL, SUBSTR(EMAIL, 1, INSTR(EMAIL, '@') - 1) ID
FROM EMPLOYEE;
--이메일에서 SITE 부분만 추출하기
SELECT EMP_NAME, EMAIL, SUBSTR(EMAIL, INSTR(EMAIL, '@') + 1) SITE
FROM EMPLOYEE;

-- 여자일 경우 이름과 월급을 추출하기
SELECT EMP_NAME "이름", SALARY "월급", SUBSTR(EMP_NO, 8, 1) "성별"
FROM EMPLOYEE                                   --  = EMP_NO
WHERE SUBSTR(EMP_NO, 8, 1) IN('2', '4');
--WHERE SUBSTR(EMP_NO, 8, 1) = '2' OR SUBSTR(EMP_NO, 8, 1) = '4'

/*
   LPAD / RPAD
   -LPAD / RPAD(문자열, 최종적으로 반환할 문자의 길이(BYTE), 덧붙이고자 하는 문자)
   -제시한 문자열에 덧붙이고자 하는 문자를 오니쪽 또는 오른쪽에 덧붙여서 최종N 길이만큼의 문자열을 반환
   
   결과값을 CHARACTER 타입으로 반환
   덧붙이고자 하는 문자: 생략 가능(공백이 기본값 ' ')
   
*/

SELECT LPAD(EMAIL, 16)
FROM EMPLOYEE;

SELECT RPAD(EMAIL, 20, '#')
FROM EMPLOYEE;

-- 주민등록번호 조회 : 501010-1123321  -> 501010-1******
SELECT EMP_NAME, EMP_NO
FROM EMPLOYEE;

SELECT RPAD('501010-1', 14, '*')
FROM DUAL;
--앞에 8자리 추출해서 뒤에 * 붙이기
SELECT EMP_NAME, SUBSTR(EMP_NO, 1, 8)
FROM EMPLOYEE;

SELECT EMP_NAME 이름, RPAD(SUBSTR(EMP_NO, 1, 8), 14, '*') "주민등록번호"
FROM EMPLOYEE;


/*
    LTRIM / RTRIM
    -LTRIM / RTRIM(문자열, 제거시키려는문자)
    -문자열의 왼쪽 또는 오른쪽에서 제거하려는 문자들을 찾아서 제거한 나머지 문자를 반환
    결과값은 CHARACTER 타입으로 나옴
    제거하려는 문자는 생략 가능(기본값 ' ' 공백 삭제)
*/

SELECT LTRIM('       K    H     ')
FROM DUAL;

SELECT RTRIM('       K    H     ')
FROM DUAL;

SELECT LTRIM('AAAAA안녕AAA', 'A')
FROM DUAL;

SELECT RTRIM('000123450000', '0')
FROM DUAL;

SELECT LTRIM('ABCDABCCASDASD', 'ABC')
FROM DUAL;

/*
    TRIM
    -TRIM(BOTH, LEADING, TRAILING '제거하려는 문자' FROM '문자열')
    -문자열의 양쪽/앞쪽/뒤쪽에 있는 특정 문자를 제거한 나머지 문자열을 반환
    BOTH/LEADING/TRAILING : 생략 시 기본값을 BOTH
*/

SELECT TRIM('A' FROM 'AAACNJNSAA')
FROM DUAL;  -- BOTH 양쪽 기본값

SELECT TRIM(LEADING 'A' FROM 'AAKMDSAASD')
FROM DUAL;  -- LEADING 왼쪽만 삭제(LTRIM과 유사)

SELECT TRIM(TRAILING 'A' FROM 'AALNLSDJFNAA')
FROM DUAL;  -- TRAILING 오른쪽만삭제(RTRIM과 유사)
