--LAST_DAY(DATE) : 해당 특정 날짜 월의 마지막 날짜를 구해서 반환(결과값은 DATE 타입)
SELECT LAST_DAY(SYSDATE)
FROM DUAL;

SELECT EMP_NAME, HIRE_DATE, LAST_DAY(HIRE_DATE)
FROM EMPLOYEE;

--EXTRACT : 년도 또는 월 또는 일 정보를 추출해서 반환한다.
--EXTRACT(YEAR FROM 날짜) : 특정 날짜로부터 연도만 추출
--EXTRACT(MONTH FROM 날짜) : 특정 날짜로부터 월만 추출
--EXTRACT(DAY FROM 날짜) : 특정 날짜로부터 일만 추출
SELECT EXTRACT(YEAR FROM SYSDATE) 연도
          , EXTRACT(MONTH FROM SYSDATE) 월
          , EXTRACT(DAY FROM SYSDATE) 일
FROM DUAL;

--사원명, 입사년도, 입사월, 입사일 조회
SELECT EMP_NAME 사원명
          , EXTRACT(YEAR FROM HIRE_DATE)입사년도, '년'
          , EXTRACT(MONTH FROM HIRE_DATE)입사월, '월' 
          , EXTRACT(DAY FROM HIRE_DATE)입사일, '일' 
FROM EMPLOYEE;
