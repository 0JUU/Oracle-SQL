-- 1. UNION (합집합) : 두 쿼리문을 수행한 결과값을 더하지만 중복은 제거

-- 부서코드가 D5이거나 급여가 300만 원 초과인 직원들 조회(직번, 직원명, 부서코드, 급여) -> OR
--부서코드가 D5인 직원들만 조회
SELECT EMP_ID, EMP_NAME, DEPT_CODE, SALARY
FROM EMPLOYEE
WHERE DEPT_CODE = 'D5';  -- 6명 조회
--급여가 300만 원 초과인 직원 조회
SELECT EMP_ID, EMP_NAME, DEPT_CODE, SALARY
FROM EMPLOYEE
WHERE SALARY > 3000000;  -- 8명 조회
-- 부서코드가 D5이거나 급여가 300만 원 초과인 직원들 조회
SELECT EMP_ID, EMP_NAME, DEPT_CODE, SALARY
FROM EMPLOYEE
WHERE DEPT_CODE = 'D5'
UNION 
SELECT EMP_ID, EMP_NAME, DEPT_CODE, SALARY
FROM EMPLOYEE
WHERE SALARY > 3000000;

-- OR연산자로
SELECT EMP_ID, EMP_NAME, DEPT_CODE, SALARY
FROM EMPLOYEE
WHERE DEPT_CODE = 'D5' OR SALARY > 3000000;

----문제-----
-- 1. 직급코드가 J6인 직원들만 조회(직번, 직원명, 부서코드, 직급코드)
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE JOB_CODE = 'J6';

-- 2. 부서코드가 D1인 직원들만 조회( 위와 동일 )
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE DEPT_CODE = 'D1';

-- UNION 연산자로
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE JOB_CODE = 'J6'
UNION
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE DEPT_CODE = 'D1';

-- OR 연산자로
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE JOB_CODE = 'J6' OR DEPT_CODE = 'D1';


-- 2. UNION ALL : 여러 개의 쿼리 결과를 더해서 중복제거 없이 보여준다
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE JOB_CODE = 'J6'
UNION ALL
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE DEPT_CODE = 'D1';  -- 9명(중복 제거X)


-- 3. INTERSECT : 교집합, 여러 쿼리 결과의 중복된 결과만을 조회 (AND)

--직급코드가 J6이고 부서코드가 D1인 직원들을 조회
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE JOB_CODE = 'J6'
INTERSECT
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE DEPT_CODE = 'D1';

-- AND 연산자로
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE JOB_CODE = 'J6' AND DEPT_CODE = 'D1';


-- 4. MINUS : 차집합, 선행 쿼리 결과에 후행 쿼리 결과를 뺀 나머지
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE JOB_CODE = 'J6'
MINUS
SELECT EMP_NO, EMP_NAME, DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE DEPT_CODE = 'D1';
