/*
     <SUBQUERY>
     하나의 주된 SQL(SELECT, CREATE, INSERT, UPDATE, ...) 안에 포함된 또하나의 SELECT문
     
     메인 SQL문을 위해 보조 역할을 하는 SELECT문
*/

-- 전체 사원의 평균 급여보다 더 많은 급여를 받고 있는 사원들의 사번과 이름, 직급코드를 조회하기
-- 1) 전체 사원의 평균 급여를 조회하기
SELECT FLOOR(AVG(SALARY))
FROM EMPLOYEE;

-- 2) 전체 사원의 평균 급여보다 많은 사원들의 사번과 이름, 직급코드를 조회하기
SELECT EMP_ID, EMP_NAME, JOB_CODE
FROM EMPLOYEE
WHERE SALARY > 3047662;

-- 3) 1)과 2)를 합쳐서 조회하기
SELECT EMP_ID, EMP_NAME, JOB_CODE
FROM EMPLOYEE
WHERE SALARY > (SELECT FLOOR(AVG(SALARY)) 
                FROM EMPLOYEE);



/*
     서브쿼리 구문
     서브쿼리를 수행한 결과값이 몇 행 몇 열이냐에 따라서 분류된다.
      
     - 단일행(단일열) 서브쿼리 : 서브쿼리를 수행한 결과값이 오로지 1개일 때(한 칸의 컬럼값으로 나올 때)
     - 다중행(단일열) 서브쿼리 : 서브쿼리를 수행한 결과값이 여러 행일 때
     - (단일행)다중열 서브쿼리 : 서브쿼리를 수행한 결과값이 여러 열일 때
     - 다중행 다중열 서브쿼리 : 서브쿼리를 수행한 결과값이 여러 행 여러 열일 때
      
     -> 서브쿼리를 수행한 결과값이 몇 행 몇 열이냐에 따라서 연산자가 달라진다.
*/


/*
      1. 단일행(단일열) 서브쿼리 (SINGLE ROW SUBQUERY)
      서브쿼리의 조회 결과값이 1개일 때 일반 연산자 사용 가능 (=, !=, >, <, >=, <=, ...)
*/

-- 전 직원의 평균 급여보다 적게 받는 사원들의 사원명과 직급코드, 급여를 조회하기
-- 1) 사원들의 평균 급여를 조회하기
SELECT FLOOR(AVG(SALARY))
FROM EMPLOYEE;  -- 평균 급여

-- 2) 전 직원의 평균 급여보다 적게 받는 사원들의 이름과 직급코드, 급여를 조회하기
SELECT EMP_NAME, JOB_CODE, SALARY
FROM EMPLOYEE
WHERE SALARY < 3047662;  -- 평균 급여보다 적게 받는 사원들

-- 3) 1)과 2)를 합쳐서 조회하기
SELECT EMP_NAME, JOB_CODE, SALARY
FROM EMPLOYEE
WHERE SALARY < (SELECT FLOOR(AVG(SALARY)) 
                FROM EMPLOYEE);  --결과값은 1행 1열 오직 1개의 값
       
       
-- 최저 급여를 받는 사원의 사번, 사원명, 직급코드, 급여, 입사일을 조회하기
-- 1) 최저 급여를 조회하기
SELECT MIN(SALARY)
FROM EMPLOYEE;  -- 1380000

-- 2) 최저 급여를 받는 사원들의 사번과 이름, 직급코드, 급여, 입사일을 조회하기
SELECT EMP_ID, EMP_NAME, JOB_CODE, SALARY, HIRE_DATE
FROM EMPLOYEE
WHERE SALARY = 1380000;

-- 1)과 2)를 합쳐서 조회하기
SELECT EMP_ID, EMP_NAME, JOB_CODE, SALARY, HIRE_DATE
FROM EMPLOYEE
WHERE SALARY = (SELECT MIN(SALARY) 
                FROM EMPLOYEE);
                

-- 부서별 급여 합이 가장 큰 부서의 부서코드와 부서명, 급여의 합을 조회하기
SELECT DEPT_CODE, DEPT_TITLE, SUM(SALARY)
FROM EMPLOYEE E, DEPARTMENT D
WHERE E.DEPT_CODE = D.DEPT_ID
GROUP BY DEPT_CODE, DEPT_TITLE
HAVING SUM(SALARY) = (SELECT MAX(SUM(SALARY))
                      FROM EMPLOYEE
                      GROUP BY DEPT_CODE);
                      


/*
       2. 다중행 서브쿼리 (MULTI ROW SUBQUERY)
       서브쿼리의 조회 결과값이 여러 행일 경우
        
       - IN (10, 20, 30) 서브쿼리 : 여러 개의 결과값 중에서도 하나라도 일치하는 것이 있다면 / NOT IN = 없다면
       - > ANY (10, 20, 30) 서브쿼리 : 여러 개의 결과값 중에 하나라도 클 경우
       - < ANY (10, 20, 30) 서브쿼리 : 여러 개의 결과값 중에 하나라도 작을 경우
        
       - > ALL : 여러 개의 결과값의 모든 값보다 클 경우(결과값 중 가장 큰 값보다 클 경우)
       - < ALL : 여러 개의 결과값의 모든 값보다 작을 경우(결과값 중 가장 작은 값보다 작을 경우)
*/

-- 각 부서별 최고 급여를 받는 사원의 이름, 직급코드, 급여를 조회하기
-- 1) 각 부서별 최고 급여를 조회하기 (여러 행, 단일 열)
SELECT MAX(SALARY)
FROM EMPLOYEE
GROUP BY DEPT_CODE;  -- 2890000, 3660000, 8000000, 3960000, 3900000, 2490000, 2550000

-- 2) 위에서 조회한 급여들을 받는 사원들을 조회하기
SELECT EMP_NAME, JOB_CODE, SALARY
FROM EMPLOYEE
WHERE SALARY IN(2890000, 3660000, 8000000, 3960000, 3900000, 2490000, 2550000);

-- 3) 합치기
SELECT EMP_NAME, JOB_CODE, SALARY
FROM EMPLOYEE
WHERE SALARY IN (SELECT MAX(SALARY)
                 FROM EMPLOYEE
                 GROUP BY DEPT_CODE);
                 
                 


/*
       3. (단일행)다중열 서브쿼리
       서브쿼리 조회 결과가 값은 한 행이지만 나열된 컬럼의 개수가 여러 개일 경우
*/

-- 최충분 사원과 같은 부서코드, 같은 직급코드에 해당하는 사원들 조회하기 (사원명, 부서코드, 직급코드, 입사일)
-- 1) 최충분의 부서코드, 직급코드 조회
SELECT DEPT_CODE, JOB_CODE
FROM EMPLOYEE
WHERE EMP_NAME = '최충분';

-- 2) 부서코드가 D5이며 직급코드가 J5인 사원 조회
SELECT EMP_NAME, DEPT_CODE, JOB_CODE, HIRE_DATE
FROM EMPLOYEE
WHERE DEPT_CODE = 'D5' AND JOB_CODE = 'J5';

-- 합치기
SELECT EMP_NAME, DEPT_CODE, JOB_CODE, HIRE_DATE
FROM EMPLOYEE
WHERE (DEPT_CODE, JOB_CODE) = (SELECT DEPT_CODE, JOB_CODE
                               FROM EMPLOYEE
                               WHERE EMP_NAME = '최충분');
                               
                               
                               

/*
       4. 다중행 다중열 서브쿼리
       서브쿼리 조회 결과가 여러 행 여러 컬럼일 경우
*/

-- 각 직급별 최소 급여를 받는 사원들 조회하기 ( 사번, 이름, 직급코드, 급여 )
-- 1) 각 직급별 최소 급여 조회
SELECT MIN(SALARY)
FROM EMPLOYEE
GROUP BY JOB_CODE;

-- 2) 위에서 구한 목록들에 해당하는 사원 조회하기
SELECT EMP_ID, EMP_NAME JOB_CODE, SALARY
FROM EMPLOYEE
WHERE (JOB_CODE, SALARY) = ('J2', 3700000)
OR (JOB_CODE, SALARY) = ('J7', 1380000)
OR (JOB_CODE, SALARY) = ('J3', 3400000)
...;

-- 위에 단계들을 하나의 쿼리문으로 합치기
SELECT EMP_ID, EMP_NAME, JOB_CODE, SALARY
FROM EMPLOYEE
WHERE (JOB_CODE, SALARY) IN (SELECT JOB_CODE, MIN(SALARY)
                             FROM EMPLOYEE
                             GROUP BY JOB_CODE);
                             
                             
                             
                             
/*
      5. 인라인뷰(INLINE VIEW)
      FROM절에 서브쿼리를 제시하는 것
      서브쿼리를 수행한 결과(RESULT SET)을 테이블 대신 사용하겠다.
*/

-- 보너스 포함 연봉이 3000만 원 이상인 사원들의 사번, 이름, 보너스 포함 연봉, 부서코드를 조회하기
SELECT EMP_ID, EMP_NAME, ((SALARY + (SALARY * NVL(BONUS, 0))) * 12) 연봉, DEPT_CODE
FROM EMPLOYEE
WHERE ((SALARY + (SALARY * NVL(BONUS, 0))) * 12) >= 30000000;

-- 인라인 뷰를 사용 : 사원명만 골라내기(보너스 포함 연봉이 3000만 원 이상인 사원들의 이름만)
SELECT EMP_NAME
FROM (SELECT EMP_ID, EMP_NAME, ((SALARY + (SALARY * NVL(BONUS, 0))) * 12) 연봉, DEPT_CODE
      FROM EMPLOYEE
      WHERE ((SALARY + (SALARY * NVL(BONUS, 0))) * 12) >= 30000000)  -- 보너스 포함 연봉이 3000만 원 이상인 사원들의 이름
WHERE DEPT_CODE IS NOT NULL;


-- 인라인 뷰를 주로 사용하는 예
-- TOP-N 분석 : 데이터베이스 상에 있는 자료 중 최상위 N개의 자료를 보기 위해 사용하는 기능

-- 전 직원 중 급여가 가장 높은 상위 5명(순위, 사원명, 급여)
-- ROWNUM : 오라클에서 제공해주는 컬럼으로 조회된 순서대로 1부터 순번을 부여해주는 컬럼이다.
SELECT ROWNUM, EMP_NAME, SALARY
FROM EMPLOYEE
WHERE ROWNUM <= 5
ORDER BY SALARY DESC;

SELECT *
FROM EMPLOYEE
ORDER BY SALARY DESC;

-- 해결 : 미리 ODER BY로 정렬된 테이블로 조회하기
SELECT ROWNUM, EMP_NAME, SALARY
FROM (SELECT *
      FROM EMPLOYEE
      ORDER BY SALARY DESC)
WHERE ROWNUM <= 5;




/*
      6. 순위 매기는 함수 (WINDOW FUNCTION)
      
      RANK() OVER(정렬 기준)
      DENSE_RANK() OVER(정렬 기준)
      -RANK() OVER : 공동 1위가 3명이라고 하면 그 다음순위는 4위로 한다.
      -DENSE_RANK() OVER : 공동 1위가 3명이어도 그 다음순위는 2위로 한다.
      
      정렬 기준 : ORDER BY절(정렬기준컬럼이름 오름차순/내림차순)
      SELECT절에서만 사용가능
*/

-- 사원들의 급여가 높은 순서대로 매겨서 사원명, 급여, 순위 조회하기 : RANK() OVER()
SELECT EMP_NAME, SALARY, RANK() OVER(ORDER BY SALARY DESC) 순위
FROM EMPLOYEE;  -- 공동 순위 인원 만큼 다음 순위가 밀린다. (공동순위 19위 2명, 그 다음 순위는 21위)

-- 사원들의 급여가 높은 순서대로 매겨서 사원명, 급여, 순위 조회하기 : DENSE_RANK() OVER()
SELECT EMP_NAME, SALARY, DENSE_RANK() OVER(ORDER BY SALARY DESC)순위
FROM EMPLOYEE;  -- 공동 순위 인원 만큼 다음 순위가 밀리지 않는다. (공동순위 19위 2명, 그 다음 순위는 20위)

-- 5위까지만 조회하기
SELECT EMP_NAME, SALARY, RANK() OVER(ORDER BY SALARY DESC) 순위
FROM EMPLOYEE
WHERE RANK() OVER(ORDER BY SALARY DESC) <= 5;  -- 에러. RANK 함수는 WHERE절에서 사용 불가

-- 인라인 뷰를 사용하여 5위까지 조회하면 된다.
SELECT *
FROM (SELECT EMP_NAME, SALARY, RANK() OVER(ORDER BY SALARY DESC) 순위
      FROM EMPLOYEE)
WHERE 순위 <= 5;
